<section class="app-preview" id="app-preview">
  <div class="container">
    <div class="fade-in">
      <span class="section-label">App Preview</span>
      <h2 class="section-title">Designed for clarity</h2>
      <p class="section-desc" style="margin: 0 auto;">A clean, intuitive interface that puts your financial future front and center.</p>
    </div>

    <div class="phones-img fade-in">
      <img src="/screens.png" alt="AnticiFi app screens — Dashboard, Oracle AI, Predictive Alerts, Import" loading="lazy">
    </div>
  </div>
</section>

<style>
  .app-preview {
    background: var(--bg-secondary);
    overflow: hidden;
  }

  .app-preview .container {
    text-align: center;
  }

  .phones-img {
    margin-top: 56px;
  }

  .phones-img img {
    width: 100%;
    max-width: 1100px;
    height: auto;
    margin: 0 auto;
    display: block;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
  }
</style>
