# ═══════════════════════════════════════════════════════════
# AnticiFi — Environment Variables
# Copy to .env and fill with real values.
# Never commit .env to the repository.
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
LOG_LEVEL=debug

# ── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=anticifi_dev
DB_USER=anticifi
DB_PASSWORD=anticifi_secret
DATABASE_URL=postgresql://anticifi:anticifi_secret@localhost:5432/anticifi_dev

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── NATS ─────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── AI/ML Service ───────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001
PREDICTION_TIMEOUT_MS=30000

# ── Email (SMTP / SendGrid) ─────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_FROM=noreply@anticifi.app

# ── Firebase (Push notifications) ────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=

# ── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE=10mb
UPLOAD_DIR=./uploads

# ── Plaid (Bank connections) ────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=
PLAID_ENCRYPTION_KEY=

# ── Monitoring (optional) ────────────────────────────────
SENTRY_DSN=
SLACK_WEBHOOK_URL=
