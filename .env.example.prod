# ═══════════════════════════════════════════════════════════
# AnticiFi — Production Environment Variables
# Copy to .env on the server and fill with real values.
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_URL=https://api.anticifi.com
LOG_LEVEL=warn

# ── PostgreSQL ───────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=anticifi_prod
DB_USER=anticifi
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://anticifi:CHANGE_ME_STRONG_PASSWORD@postgres:5432/anticifi_prod

# Connection pool
DB_POOL_MIN=5
DB_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── NATS ─────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── AI/ML Service ───────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
PREDICTION_TIMEOUT_MS=30000

# ── Email (SMTP / SendGrid) ─────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_FROM=noreply@anticifi.com

# ── Firebase (Push notifications) ────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=

# ── Plaid (Bank connections) ────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_WEBHOOK_URL=https://api.anticifi.com/api/plaid/webhook
PLAID_ENCRYPTION_KEY=

# ── RevenueCat ──────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=

# ── Monitoring (optional) ────────────────────────────────
SENTRY_DSN=
SLACK_WEBHOOK_URL=
